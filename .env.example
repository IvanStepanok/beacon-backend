# Beacon backend configuration (all optional — sane defaults baked in).
#
# PRODUCTION SECRETS (used by docker-compose.yml ${VAR} interpolation): copy this
# file to backend/.env on the deploy host and fill in REAL values. backend/.env is
# gitignored and must NEVER be committed.
POSTGRES_PASSWORD=change-me-strong-db-password
JWT_SECRET=change-me-32+-byte-random-hex

DATABASE_URL=postgres://beacon:beacon@localhost:5544/beacon?sslmode=disable
HTTP_ADDR=:8080
ENV=dev                       # dev | prod (prod => JSON logs + analyst bearer enforced)
PGX_MAX_CONNS=20
READ_TIMEOUT_SEC=15
WRITE_TIMEOUT_SEC=30
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_RPS=20
RUN_SEED=true                 # seed the Antakya dataset on an empty DB
SEED_DATASET=dashboard        # dashboard (56) | mobile (adds b-47 version chain) | both
ANALYST_TOKEN=beacon-analyst-dev
LOG_LEVEL=info                # debug | info | warn | error
