# Beacon backend configuration (all optional — sane defaults baked in).
#
# PRODUCTION SECRETS (used by docker-compose.yml ${VAR} interpolation): copy this
# file to backend/.env on the deploy host and fill in REAL values. backend/.env is
# gitignored and must NEVER be committed.
POSTGRES_PASSWORD=change-me-strong-db-password
JWT_SECRET=change-me-32+-byte-random-hex
# AES-256 key for at-rest encryption of report photos + analyst MFA secrets.
# Generate with:  openssl rand -base64 32
# REQUIRED when ENV=prod (the backend fails to boot without it). Rotating it makes
# previously-encrypted photos/MFA secrets unreadable, so rotate deliberately.
DATA_ENCRYPTION_KEY=change-me-run-openssl-rand-base64-32

# Local dev DB has no TLS, so sslmode=disable is fine here. When ENV=prod the backend
# REQUIRES sslmode=require|verify-ca|verify-full and refuses to boot on disable/prefer.
DATABASE_URL=postgres://beacon:beacon@localhost:5544/beacon?sslmode=disable
HTTP_ADDR=:8080
ENV=dev                       # dev | prod (prod => JSON logs + analyst bearer enforced)
PGX_MAX_CONNS=20
READ_TIMEOUT_SEC=15
WRITE_TIMEOUT_SEC=30
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_RPS=20
RUN_SEED=true                 # seed the Antakya dataset on an empty DB
SEED_DATASET=dashboard        # dashboard (56) | mobile (adds b-47 version chain) | both
ANALYST_TOKEN=beacon-analyst-dev
LOG_LEVEL=info                # debug | info | warn | error

# Emergent-crisis clustering thresholds (see docs/CRISIS-LIFECYCLE.md). A cluster of
# EMERGENT_MIN_REPORTS *distinct* submitters within EMERGENT_RADIUS_KM over the last
# EMERGENT_WINDOW_HRS, in one admin area, proposes a crisis for analyst review — never
# auto-activated. MIN_REPORTS must be >= 2 (one report can never be a crisis).
BEACON_EMERGENT_RADIUS_KM=2.0
BEACON_EMERGENT_WINDOW_HRS=24
BEACON_EMERGENT_MIN_REPORTS=3
